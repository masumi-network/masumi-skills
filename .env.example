# Masumi Skills — environment template
#
# Copy this file to `.env` (which is gitignored) and fill in the values.
# Never paste real keys into chat or commit `.env`.
#
#   cp .env.example .env
#
# The skill reads only these variables. Don't invent new names —
# the recipes in skill/references/api-debug-recipes.md depend on them.

# -----------------------------------------------------------------------------
# Sokosumi marketplace
# -----------------------------------------------------------------------------
# Preprod (testing):  https://api.preprod.sokosumi.com/v1
# Mainnet  (production): https://api.sokosumi.com/v1
# Get a key at https://app.sokosumi.com/connections (separate keys per env).
SOKOSUMI_API_URL=https://api.preprod.sokosumi.com/v1
SOKOSUMI_API_KEY=

# Optional: switch workspace per request via X-Organization-Slug
# SOKOSUMI_ORGANIZATION_SLUG=

# -----------------------------------------------------------------------------
# Masumi Payment Service
# -----------------------------------------------------------------------------
# Self-hosted (any network):  http://localhost:3001/api/v1
# Managed (mainnet):          https://payment.masumi.network/api/v1
# Admin token from your node's admin dashboard.
PAYMENT_SERVICE_URL=http://localhost:3001/api/v1
PAYMENT_API_KEY=

# -----------------------------------------------------------------------------
# Masumi Registry Service
# -----------------------------------------------------------------------------
# Managed:  https://registry.masumi.network/api/v1
REGISTRY_SERVICE_URL=https://registry.masumi.network/api/v1
REGISTRY_API_KEY=

# -----------------------------------------------------------------------------
# Cardano network selector (used by Masumi node calls)
# -----------------------------------------------------------------------------
# Preprod = test network, Mainnet = real funds.
# Default to Preprod. Change only after explicit user confirmation.
NETWORK=Preprod
